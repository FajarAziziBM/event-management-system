# =============================================================
# APPLICATION
# =============================================================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
TZ=Asia/Jakarta

# =============================================================
# DATABASE (MySQL via Sequelize)
# =============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ems_db
DB_USER=root
DB_PASSWORD=

# =============================================================
# AUTH & SECURITY
# =============================================================
# Generate string acak & panjang, contoh: `openssl rand -hex 32`
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=1d
COOKIE_SECRET=replace_with_a_long_random_string
# Set true hanya jika aplikasi diakses via HTTPS (wajib true di production)
COOKIE_SECURE=false
CSRF_SECRET=replace_with_a_long_random_string
BCRYPT_SALT_ROUNDS=12
# Daftar origin yang diizinkan CORS, pisahkan dengan koma bila lebih dari satu
CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================
# ORDER & TICKET
# =============================================================
# Batas waktu order berstatus "pending" sebelum otomatis di-expired (menit)
ORDER_EXPIRY_MINUTES=60

# =============================================================
# XENDIT PAYMENT GATEWAY
# =============================================================
# Xendit Dashboard -> Settings -> API Keys (pakai mode Test untuk development)
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxxxxxx
# Xendit Dashboard -> Settings -> Webhooks -> Verification Token
XENDIT_CALLBACK_TOKEN=replace_with_xendit_webhook_verification_token
XENDIT_SUCCESS_REDIRECT_URL=http://localhost:3000/orders/success
XENDIT_FAILURE_REDIRECT_URL=http://localhost:3000/orders/failed

# =============================================================
# EMAIL / SMTP (Nodemailer)
# =============================================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=no-reply@example.com

# =============================================================
# RATE LIMITING
# =============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# =============================================================
# FILE UPLOAD
# =============================================================
UPLOAD_DIR=src/public/uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# =============================================================
# LOGGING
# =============================================================
# error | warn | info | http | debug
LOG_LEVEL=debug
