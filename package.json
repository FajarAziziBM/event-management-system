{
  "name": "event-management-system",
  "version": "1.0.0",
  "description": "Backend API untuk platform manajemen event & ticketing online. Mendukung pembuatan event oleh organizer, penjualan tiket ke customer, serta pembayaran otomatis melalui **Xendit** (Virtual Account, E-Wallet, Kartu Kredit, QRIS) dengan sinkronisasi status pembayaran secara real-time via **Webhook**.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FajarAziziBM/event-management-system.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/FajarAziziBM/event-management-system/issues"
  },
  "homepage": "https://github.com/FajarAziziBM/event-management-system#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "sequelize": "^6.37.8",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xendit-node": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2"
  }
}
