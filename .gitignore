# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# Build output
dist/
build/

# User-uploaded files (jangan di-version, hanya struktur foldernya)
src/public/uploads/*
!src/public/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp

# Lint/format cache
.eslintcache

# Husky internal runtime dir (hook file-nya sendiri tetap di-commit)
.husky/_/

# Misc
*.pid
*.pid.lock
*.seed
