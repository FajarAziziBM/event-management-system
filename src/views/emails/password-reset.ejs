<%- include('../partials/header', { title: 'Reset Password' }) %>
<h2 style="font-family: Georgia, 'Times New Roman', serif; margin-top: 0">Reset Password</h2>
<p>
  Halo <%= name %>, kami menerima permintaan untuk reset password akun Anda. Klik tombol di
  bawah untuk membuat password baru (link berlaku 1 jam):
</p>
<p style="text-align: center; margin: 32px 0">
  <a
    href="<%= resetUrl %>"
    style="background-color: #d6a419; color: #14232e; padding: 12px 28px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block"
    >Reset Password</a
  >
</p>
<p style="color: #5b6670; font-size: 13px">
  Jika Anda tidak meminta reset password, abaikan email ini — password Anda tidak akan berubah.
</p>
<%- include('../partials/footer') %>
