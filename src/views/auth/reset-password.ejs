<%# src/views/auth/reset-password.ejs %>
<section class="auth-container">
  <div class="auth-card">
    <h1>Reset Password</h1>
    <p class="auth-subtitle">Buat password baru untuk akun Anda</p>

    <form method="post" action="/auth/reset-password" class="auth-form">
      <input type="hidden" name="token" value="<%= token %>" />

      <div class="form-group">
        <label for="newPassword">Password Baru</label>
        <input type="password" id="newPassword" name="newPassword" required />
        <small>Minimal 8 karakter, harus ada huruf besar, kecil, dan angka</small>
      </div>

      <div class="form-group">
        <label for="newPasswordConfirm">Konfirmasi Password</label>
        <input type="password" id="newPasswordConfirm" name="newPasswordConfirm" required />
      </div>

      <button type="submit" class="btn btn--primary">Reset Password</button>
    </form>

    <p class="auth-footer">
      <a href="/auth/login">Kembali ke login</a>
    </p>
  </div>
</section>
